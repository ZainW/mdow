{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // .tool_response.filePath' | { read -r f; npx oxfmt --write \"$f\"; } 2>/dev/null || true",
            "timeout": 30,
            "statusMessage": "Formatting..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pnpm run lint 2>&1 || true",
            "timeout": 60,
            "statusMessage": "Linting..."
          }
        ]
      }
    ]
  }
}
