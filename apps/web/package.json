{
  "name": "web",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "node scripts/generate-rss.mjs && node scripts/sync-docs-md.mjs && vite build",
    "generate:static": "node scripts/generate-rss.mjs && node scripts/sync-docs-md.mjs",
    "generate:og": "node scripts/generate-og-image.mjs",
    "preview": "vite preview",
    "deploy": "pnpm run build && wrangler deploy",
    "cf-typegen": "wrangler types",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check .",
    "test": "vitest run"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@tanstack/react-router": "^1.170.10",
    "@tanstack/react-start": "^1.168.18",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fuse.js": "^7.4.0",
    "md4x": "^0.0.25",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "shiki": "^4.1.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.39.1",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^29.1.1",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "wrangler": "^4.96.0"
  }
}
