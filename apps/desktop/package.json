{
  "name": "desktop",
  "version": "1.4.0",
  "private": true,
  "description": "A quiet place to read markdown",
  "author": "Zain Wania",
  "repository": {
    "type": "git",
    "url": "https://github.com/ZainW/mdow.git"
  },
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck:node": "tsgo --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsgo --noEmit -p tsconfig.web.json",
    "typecheck": "pnpm run typecheck:node && pnpm run typecheck:web",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:electron:perf": "electron-vite build && node perf/electron-render.perf.mjs",
    "test:icons:visual": "VITE_ICON_LAB=true electron-vite build && node perf/icon-visual-compare.mjs",
    "screenshots:web": "electron-vite build && node scripts/capture-website-screenshots.mjs",
    "build:dist": "electron-vite build && electron-builder",
    "publish": "electron-vite build && electron-builder --publish always",
    "postinstall": "electron-builder install-app-deps && bash scripts/patch-electron-name.sh"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@comark/react": "^0.3.1",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@pierre/trees": "1.0.0-beta.4",
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-query": "^5.100.14",
    "@tanstack/react-virtual": "^3.14.1",
    "chokidar": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "comark": "^0.3.2",
    "electron-log": "^5.4.4",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "katex": "^0.17.0",
    "lucide-react": "^1.17.0",
    "mermaid": "^11.15.0",
    "ocache": "^0.1.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "shiki": "^4.1.0",
    "tailwind-merge": "^3.6.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260601.1",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "jsdom": "^29.1.1",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "oxlint-tsgolint": "^0.23.0",
    "playwright": "^1.60.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^7.3.5",
    "vitest": "^4.1.8"
  },
  "productName": "Mdow"
}
