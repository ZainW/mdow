{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mdow",
  "version": "1.0.3",
  "identifier": "com.zainw.mdow",
  "build": {
    "beforeDevCommand": "pnpm run tauri:vite:dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm run tauri:vite:build",
    "frontendDist": "../dist-tauri"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Mdow",
        "width": 1200,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["../resources/icon.icns", "../resources/icon.ico", "../resources/icon.png"]
  }
}
