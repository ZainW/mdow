{
  "$schema": "https://raw.githubusercontent.com/nicolo-ribaudo/oxlint-schema-mirror/main/configuration_schema.json",
  "plugins": ["react", "typescript", "unicorn", "import", "jsx-a11y", "oxc"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn",
    "pedantic": "off",
    "style": "off",
    "restriction": "off",
    "nursery": "off"
  },
  "options": {
    "typeAware": true,
    "typeCheck": true
  },
  "env": {
    "browser": true,
    "es2024": true,
    "node": true
  },
  "settings": {
    "react": {
      "version": "19.0.0"
    }
  },
  "rules": {
    "react/react-in-jsx-scope": "off",
    "import/no-unassigned-import": "off",
    "no-shadow": "off",
    "typescript/no-floating-promises": "error",
    "typescript/no-misused-promises": "error",
    "typescript/await-thenable": "error",
    "typescript/no-unnecessary-type-assertion": "warn",
    "typescript/no-unsafe-assignment": "warn",
    "typescript/no-unsafe-call": "warn",
    "typescript/no-unsafe-member-access": "warn",
    "typescript/no-unsafe-return": "warn",
    "typescript/no-unsafe-argument": "warn",
    "typescript/restrict-template-expressions": "warn",
    "typescript/no-for-in-array": "error",
    "typescript/no-implied-eval": "error",
    "typescript/require-await": "warn",
    "typescript/no-unnecessary-type-arguments": "warn",
    "typescript/no-redundant-type-constituents": "warn",
    "typescript/no-duplicate-type-constituents": "error",
    "typescript/switch-exhaustiveness-check": "warn",
    "typescript/use-unknown-in-catch-callback-variable": "warn"
  },
  "ignorePatterns": ["out/**", "dist/**", "node_modules/**", "*.js", "*.mjs"]
}
